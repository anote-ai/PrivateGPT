# PrivateGPT Backend Environment Variables
# Copy this file to .env and fill in your values
# Never commit the .env file to version control

# Database Configuration (MySQL production)
DB_HOST=your-db-host.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=your-db-password
DB_NAME=privategpt

# SEC EDGAR API Key (get from https://sec-api.io)
SEC_API_KEY=your-sec-api-key-here

# OpenAI API Key (optional, for embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# SQLite DB path (for local/desktop builds, leave blank for default ./database.db)
DB_PATH=./database.db
